# Contoh environment variables untuk production\n# Salin ke .env.local dan isi nilai sebenarnya\n\n# Google Maps API Key (jika digunakan di MapSection atau components)\nNEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here\n\n# Google Gemini API Key (jika diperlukan)\nGEMINI_API_KEY=your_gemini_api_key_here\n\n# Domain Vercel (auto-set by Vercel)\n# VERCEL_URL=your-vercel-app.vercel.app\n
